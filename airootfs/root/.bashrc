#
# AcreetionOS Live — root .bashrc
#

alias ls='ls --color=auto'
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'
alias grep='grep --color=auto'
alias ..='cd ..'

PS1='\[\e[1;32m\][\u@\h \W]\$\[\e[0m\] '

echo "Welcome to AcreetionOS Sway Live!"
echo "Type 'installation_guide' for setup instructions."
